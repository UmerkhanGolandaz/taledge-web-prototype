NEXT_PUBLIC_FIREBASE_API_KEY="your-api-key"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-auth-domain.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-project-id"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your-project-id.appspot.com"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="your-messaging-sender-id"
NEXT_PUBLIC_FIREBASE_APP_ID="your-app-id"

# DNLA interview question API — PLACEHOLDER, change later. Leave empty to make the
# DNLA interview reuse the same Gemini question generation as the AI interview.
DNLA_QUESTION_API_URL=""
DNLA_QUESTION_API_KEY=""

# Interviewer voice — OPTIONAL. Default is Gemini TTS (uses GEMINI_API_KEY).
# To upgrade to Google Cloud Chirp 3 HD voices, enable the Cloud Text-to-Speech
# API and set a key here; leave empty to keep the default Gemini voice.
GOOGLE_TTS_API_KEY=""
GOOGLE_TTS_VOICE="en-US-Chirp3-HD-Leda"