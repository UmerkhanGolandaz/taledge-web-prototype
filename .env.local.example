NEXT_PUBLIC_FIREBASE_API_KEY="your-api-key"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-auth-domain.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-project-id"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your-project-id.appspot.com"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="your-messaging-sender-id"
NEXT_PUBLIC_FIREBASE_APP_ID="your-app-id"

# DNLA interview question API — PLACEHOLDER, change later. Leave empty to make the
# DNLA interview reuse the same Gemini question generation as the AI interview.
DNLA_QUESTION_API_URL=""
DNLA_QUESTION_API_KEY=""

# --- DNLA Partner API (real psychometric assessment) -------------------------
# Server-only partner key for backend.dnla.com (the `api_key` shown as required
# on every endpoint). Powers the real flow: create TAN -> DNLA-hosted
# questionnaire -> completion webhook -> results -> Fit Score. Leave empty to
# keep DNLA in "pending import" mode (the app still runs without it).
DNLA_API_KEY=""
DNLA_API_BASE="https://backend.dnla.com"
DNLA_AREA="ESK"
# Shared secret that authenticates DNLA's completion webhook. Register the
# webhook URL as  https://<your-domain>/api/dnla/webhook?secret=<this-value>
DNLA_WEBHOOK_SECRET=""
# Result-scale calibration — CONFIRM WITH DNLA. Max raw `values` and polarity
# (set HIGHER_IS_BETTER=false if 1 = best). Wrong values only mis-scale, never crash.
DNLA_SCALE_MAX="9"
DNLA_SCALE_HIGHER_IS_BETTER="true"

# For production scale (1000+ candidates): set the Firebase Admin service account
# so sessions/DNLA results persist in Firestore instead of the dev file fallback.
# FIREBASE_SERVICE_ACCOUNT='{ ...service-account JSON... }'

# Interviewer voice — OPTIONAL. Default is Gemini TTS (uses GEMINI_API_KEY).
# To upgrade to Google Cloud Chirp 3 HD voices, enable the Cloud Text-to-Speech
# API and set a key here; leave empty to keep the default Gemini voice.
GOOGLE_TTS_API_KEY=""
GOOGLE_TTS_VOICE="en-US-Chirp3-HD-Leda"