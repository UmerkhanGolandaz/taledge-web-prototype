# =============================================================================
# Taledge environment configuration
# Copy to .env.local and fill in. See SECURITY.md for the production posture.
# =============================================================================

# --- Gemini (required for AI features) ---------------------------------------
# Get your key at: https://aistudio.google.com/apikey
# IMPORTANT: this is a SERVER-ONLY secret. Never expose it to the client
# (no NEXT_PUBLIC_ prefix). It was previously leaked client-side, so any old
# key MUST be rotated before going to production. See SECURITY.md.
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025

# --- DNLA interview question API (PLACEHOLDER — CHANGE LATER) -----------------
# The DNLA interview round is wired to pull its questions from the licensed DNLA
# provider (Germany). That endpoint does not exist yet, so for now the DNLA
# interview falls back to the SAME Gemini question generation as the AI
# interview. When the provider ships their question API, set the URL (and key if
# required) below and update lib/dnla-questions.ts to map their response shape.
# TODO: replace with the real DNLA question API endpoint.
DNLA_QUESTION_API_URL=
DNLA_QUESTION_API_KEY=

# --- Authentication enforcement ----------------------------------------------
# false (default): demo/dev mode. Routes resolve a stable non-authoritative
#   "demo-user" principal so the seeded personas stay browsable without login.
# true: production mode. Every API route and protected page REQUIRES a verified
#   Firebase ID token; firebase-admin MUST be configured (see below).
AUTH_ENFORCED=false

# --- Firebase Admin (server-side token verification + privileged Firestore) --
# Required when AUTH_ENFORCED=true. Provide EITHER:
#   FIREBASE_SERVICE_ACCOUNT       = full service-account JSON, stringified
#   GOOGLE_APPLICATION_CREDENTIALS = path to a service-account JSON file (ADC)
# If NEITHER is set, admin is not initialized and the app degrades to demo mode.
# Leave empty for local dev.
FIREBASE_SERVICE_ACCOUNT=
# GOOGLE_APPLICATION_CREDENTIALS=

# --- Feature flags -----------------------------------------------------------
# Show Phase-2 (AI Coach) surfaces in navigation. Client-visible flag.
NEXT_PUBLIC_SHOW_PHASE_2=false
